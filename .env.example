# Environment Configuration for roomworkingAi

# Application
NODE_ENV=development
PORT=3000
HOST=localhost

# Security
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
COOKIE_SECRET=your-cookie-signing-secret-change-this-too

# Database (if needed later)
# DATABASE_URL=
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=roomworkingai
# DB_USER=
# DB_PASSWORD=

# AI/API Keys (for future integrations)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100